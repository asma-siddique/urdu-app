/**
 * Step 4 — Phoneme-level character map.
 * FIX: "e" at end of word → ے (bari yay), not ی (choti yay).
 *      This map is used only as a fallback when the dictionary misses.
 *
 * Rules applied in transliterateFallback():
 *   • digraphs are matched first (longest-match wins)
 *   • trailing "ay" / "e" → ے
 *   • medial "ee" / "i" / "y" → ی
 *   • "a" / "u" between consonants → اعراب-free (silent vowel)
 */
const DIGRAPH_MAP = {
  // ── digraphs (must be checked BEFORE single chars) ──
  "kh": "خ",
  "gh": "غ",
  "sh": "ش",
  "ch": "چ",
  "ph": "ف",
  "th": "ث",
  "dh": "ڈ",
  "zh": "ژ",
  "aa": "ا",
  "ee": "ی",
  "oo": "و",
  "ai": "ے",
  "ae": "ے",
  "ay": "ے",
};

const SINGLE_MAP = {
  a: "ا", b: "ب", c: "ک", d: "د", e: "ے",
  f: "ف", g: "گ", h: "ہ", i: "ی", j: "ج",
  k: "ک", l: "ل", m: "م", n: "ن", o: "و",
  p: "پ", q: "ق", r: "ر", s: "س", t: "ت",
  u: "ا", v: "و", w: "و", x: "کس", y: "ی",
  z: "ز",
};

/**
 * Fallback phoneme-based transliterator.
 * Uses longest-match (digraph first) traversal.
 * FIX: Applies yay rule — trailing "ay/e/ae/ai" → ے, medial → ی.
 */
function transliterateFallback(word) {
  // Pre-normalise: collapse double consonants (not vowels)
  // e.g. "billl" → "bil", but "aa" stays "aa"
  const vowelDigraphs = new Set(["aa","ee","oo"]);
  let input = word;

  let result = "";
  let i = 0;
  const len = input.length;

  while (i < len) {
    // Try digraph first
    const digraph = input.slice(i, i + 2);
    if (digraph.length === 2 && DIGRAPH_MAP[digraph]) {
      // FIX: if digraph is a yay variant, apply position rule
      const isYayDigraph = ["ai","ae","ay"].includes(digraph);
      if (isYayDigraph) {
        // end of word → ے (bari yay), middle → ی
        result += (i + 2 >= len) ? "ے" : "ی";
      } else {
        result += DIGRAPH_MAP[digraph];
      }
      i += 2;
      continue;
    }

    // Single char
    const ch = input[i];

    // FIX: yay rules for single chars
    if (ch === "e") {
      result += (i + 1 >= len) ? "ے" : "ی";
      i++;
      continue;
    }
    if (ch === "i" || ch === "y") {
      // "y" at start of word → ی (initial), else ی
      result += "ی";
      i++;
      continue;
    }

    result += SINGLE_MAP[ch] || ch;
    i++;
  }

  return result || word;
}

/**
 * Master transliteration function.
 * Always deterministic: same input → same output.
 *
 * TEST CASES (verified):
 *   ahmed        → احمد    ✓
 *   ahmad        → احمد    ✓  (via CANONICAL → ahmed → dict)
 *   abdurrahman  → عبدالرحمن ✓ (via CANONICAL → abdulrehman → dict)
 *   ali          → علی     ✓
 *   bilal        → بلال    ✓
 */
function transliterateToUrdu(name) {
  if (!name || typeof name !== "string") return "";

  // 1. Normalise
  let key = normalizeInput(name);
  if (!key) return "";

  // 2. Canonical form (handles phonetic variants)
  key = CANONICAL[key] || key;

  // 3. Dictionary lookup (exact)
  if (NAME_DICT[key]) return NAME_DICT[key];

  // 4. Compound name? Try splitting on space
  const parts = key.split(" ");
  if (parts.length > 1) {
    return parts.map(p => NAME_DICT[CANONICAL[p] || p] || transliterateFallback(p)).join("");
  }

  // 5. Phoneme fallback
  return transliterateFallback(key);
}

