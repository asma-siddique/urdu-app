/**
 * Levenshtein distance between two strings.
 * Used to compute edit-distance for scoring.
 */
function levenshtein(a, b) {
  const m = a.length, n = b.length;
  const dp = Array.from({ length: m + 1 }, (_, i) =>
    Array.from({ length: n + 1 }, (_, j) => (i === 0 ? j : j === 0 ? i : 0))
  );
  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      dp[i][j] = a[i - 1] === b[j - 1]
        ? dp[i - 1][j - 1]
        : 1 + Math.min(dp[i - 1][j], dp[i][j - 1], dp[i - 1][j - 1]);
    }
  }
  return dp[m][n];
}
function isConsonant(c) {
  return !["a","e","i","o","u","y"].includes(c);
}
/**
 * Normalise a romanised Urdu string for comparison:
 *   - lowercase
 *   - trim
 *   - collapse equivalent vowel spellings
 *     aa→a, oo→u, ee→i, ai/ae/ay→ay
 *   - remove trailing 'h' (aspirated consonant marker often dropped)
 */
// Line 333 (approx) - REPLACING THE OLD normalizeRoman
/**
 * EXPERT URDU NORMALIZER
 * Collapses equivalent sounds (k/q, vowels, aspirated)
 */
function normalizeRoman(str) {
  if (!str) return "";
  
  let n = str.toLowerCase().trim();

  // 1. Protect Aspirated Consonants (gh, kh, ph, etc.) 
  // We temporarily convert them to symbols to prevent the 'h' from being stripped
  n = n.replace(/kh/g, "X")
       .replace(/gh/g, "G")
       .replace(/sh/g, "S")
       .replace(/ch/g, "C")
       .replace(/ph/g, "F")
       .replace(/th/g, "T")
       .replace(/dh/g, "D")
       .replace(/rh/g, "R");
      // 3. THE "GHAR/GARH" FIX: Consolidated Aspiration
  // We treat [consonant]+h as a single unit so the 'h' doesn't drift
  n = n.replace(/([kgpbdjct])h/g, "$1"); // Treat 'gh' as 'g', 'kh' as 'k', etc. for scoring

  // 2. Consonant Sound Equivalents
  n = n.replace(/q/g, "k")     // k and q are same
       .replace(/z|zh/g, "z")  // z and zh overlap
       .replace(/v/g, "w")     // v and w are same in Urdu (و)
       .replace(/c/g, "k");    // solitary c usually sounds like k

  // 3. Vowel Collapsing (Leniency Rule)
  n = n.replace(/aa+/g, "a")
       .replace(/ee+|iy/g, "i")
       .replace(/oo+|uu+/g, "u")
       .replace(/ae|ai|ay/g, "e");

  // 4. Handle remaining 'h' 
  // Remove silent trailing h, but keep the protected "X, G, S" etc.
  n = n.replace(/h$/g, "");

  // 5. Cleanup
  return n.replace(/\s+/g, "");
}
/**
 * Build a set of accepted romanisations for a word.
 * Includes the canonical form plus common variants.
 */
function buildAcceptedForms(romanized) {
  const base = normalizeRoman(romanized);
  const variants = new Set([base]);
  // Allow with/without double vowels
  variants.add(base);

  // trailing h optional
  variants.add(base + "h");
  return variants;
}

