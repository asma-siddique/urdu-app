/**
 * Step 1 — Normalise input: lowercase + trim + collapse whitespace.
 * Stripping duplicate consecutive letters is intentionally NOT done
 * globally because "aa", "ee", "oo" are valid long-vowel markers.
 */
function normalizeInput(str) {
  if (!str) return "";
  return str.toLowerCase().trim().replace(/\s+/g, " ");
}

