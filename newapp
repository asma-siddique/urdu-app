// ═══════════════════════════════════════════════════════════════════
// FIX: Quiz question builder — removed Math.random() from option
//      shuffling. Options are now sorted deterministically by string
//      to prevent different orderings on each render.
//      The quiz itself is built once via useState initializer.
// ═══════════════════════════════════════════════════════════════════

// Seeded pseudo-random shuffle (deterministic per session seed).
// Uses a simple LCG so the quiz feels varied across sessions but
// a given seed always produces the same order.
function seededShuffle(arr, seed) {
  const a = [...arr];
  let s = seed;
  for (let i = a.length - 1; i > 0; i--) {
    s = (s * 1664525 + 1013904223) & 0xffffffff;
    const j = Math.abs(s) % (i + 1);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// Stable seed based on the day (changes daily, not on each render).
const DAY_SEED = Math.floor(Date.now() / 86400000);

const buildQuestions = () => {
  const LETTER_DISTRACTORS = ["Meem","Bay","Seen","Kaaf","Laam","Noon","Tay","Ray"];
  const WORD_DISTRACTORS   = ["Cat","Book","Water","Tree","Bird","Sun","Moon","Apple"];

  const letterQs = FULL_ALPHABET.slice(0, 15).map((l, idx) => {
    const distractors = LETTER_DISTRACTORS.filter(x => x !== l.r).slice(0, 3);
    const opts = seededShuffle([l.r, ...distractors], DAY_SEED + idx);
    return {
      q: "Which letter is this?", qUrdu: "یہ حرف کون سا ہے؟", urdu: l.u,
      options: opts,
      answer: l.r, type: "letter",
    };
  });

  const wordQs = WORDS.slice(0, 12).map((w, idx) => {
    const distractors = WORD_DISTRACTORS.filter(x => x !== w.eng).slice(0, 3);
    const opts = seededShuffle([w.eng, ...distractors], DAY_SEED + 100 + idx);
    return {
      q: `What does "${w.u}" mean?`, qUrdu: `"${w.u}" کا مطلب کیا ہے؟`, urdu: w.emoji,
      options: opts,
      answer: w.eng, type: "word",
    };
  });

  return seededShuffle([...letterQs, ...wordQs], DAY_SEED + 999).slice(0, 10);
};

