// ─── WAVEFORM ────────────────────────────────────────────────────
// FIX: Decorative only. Removed randomness from score display.
//      Active animation still uses interval (UI effect, not logic).
function Waveform({ active, score }) {
  const [bars, setBars] = useState(Array(18).fill(5));

  useEffect(() => {
    if (!active) {
      // FIX: score display is deterministic (sine wave shaped to score)
      if (score != null) {
        setBars(Array(18).fill(0).map((_, i) => 5 + Math.abs(Math.sin(i * 0.7)) * Math.min(28, score * 0.32)));
      } else {
        setBars(Array(18).fill(5));
      }
      return;
    }
    // Active: animate bars (visual feedback only, not used for scoring)
    let frame = 0;
    const t = setInterval(() => {
      frame++;
      setBars(Array(18).fill(0).map((_, i) => 5 + Math.abs(Math.sin(i * 0.5 + frame * 0.3)) * 32));
    }, 90);
    return () => clearInterval(t);
  }, [active, score]);

  const color = score != null ? (score > 75 ? T.green : score > 50 ? T.yellow : T.red) : active ? T.teal : T.border;
  return (
    <div style={{ display: "flex", alignItems: "center", gap: 3, height: 48, justifyContent: "center" }}>
      {bars.map((h, i) => (
        <div key={i} style={{
          width: 5, height: Math.max(4, h),
          background: color, borderRadius: 4,
          transition: active ? "height 0.09s" : "height 0.5s",
          boxShadow: active ? `0 0 6px ${color}80` : "none",
        }} />
      ))}
    </div>
  );
}

