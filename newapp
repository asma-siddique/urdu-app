// ═══════════════════════════════════════════════════════════════════
// LAFZ SCREEN  — FULLY REFACTORED
//
// REMOVED:
//   • async evaluatePronunciation() → fetch() call to Anthropic API
//   • isEvaluating / loading skeleton (no async needed)
//   • error state for network failures
//   • "🤖 AI Eval" badge in header
//   • "Ustaad AI says:" label
//
// REPLACED WITH:
//   • evaluatePronunciationLocal() — synchronous, deterministic
//   • Instant feedback on button click (no spinner needed)
//   • Same result object shape → UI components unchanged
// ═══════════════════════════════════════════════════════════════════
function LafzScreen({ onBack, onComplete }) {
  const [idx, setIdx]             = useState(0);
  const [userInput, setUserInput] = useState("");
  const [inputFocus, setInputFocus] = useState(false);
  const [evalResult, setEvalResult] = useState(null);
  const [showConfetti, setShowConfetti] = useState(false);
  const word = WORDS[idx];

  const score = evalResult ? Math.round(evalResult.accuracy) : null;
  const mood  = score == null ? "neutral" : score > 75 ? "praise" : score > 50 ? "thinking" : "sad";
  const tutorMsg = score == null
    ? `"${word.u}" means "${word.eng}"! Type how you said it! 🎤`
    : score > 75 ? `Excellent! "${word.r}" — Perfect pronunciation! 🌟`
    : score > 50 ? `Good try! Say "${word.r}" again! 💪`
    : `Let's try again — say "${word.r}" slowly! 🐢`;

  // FIX: synchronous — no async, no API, no spinner needed
  const handleEvaluate = () => {
    if (!userInput.trim()) return;
    const result = evaluatePronunciationLocal(word.u, word.r, word.phonemes, userInput.trim());
    setEvalResult(result);
    if (result.accuracy > 75) {
      setShowConfetti(true);
      setTimeout(() => setShowConfetti(false), 2000);
    }
  };

  const handleNext = () => {
    setIdx(i => (i + 1) % WORDS.length);
    setEvalResult(null);
    setUserInput("");
  };

  // FIX: reset evalResult when user starts typing a new answer
  const handleInputChange = (e) => {
    setUserInput(e.target.value);
    setEvalResult(null);
  };

  const getPhonemeStatus = (ph) => {
    if (!evalResult) return null;
    if ((evalResult.correct_phonemes || []).includes(ph))                                     return "correct";
    if ((evalResult.incorrect_phonemes || []).includes(ph) || (evalResult.missing_phonemes || []).includes(ph)) return "incorrect";
    return "unknown";
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", height: "100%", background: "linear-gradient(180deg,#e0f7ff,#fff9f0)", position: "relative" }}>
      <Confetti active={showConfetti} />
      <div style={{ background: `linear-gradient(90deg, ${T.teal}, ${T.tealD})`, padding: "12px 16px", display: "flex", alignItems: "center", gap: 12, flexShrink: 0 }}>
        <button onClick={onBack} style={{ background: "rgba(255,255,255,0.2)", border: "none", color: "white", fontSize: 18, cursor: "pointer", borderRadius: 10, width: 34, height: 34, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700 }}>←</button>
        {/* FIX: removed "🤖 AI Eval" badge */}
        <div style={{ fontWeight: 800, color: "white", fontSize: 15, flex: 1 }}>💬 الفاظ — Words</div>
        <div style={{ background: "rgba(255,255,255,0.2)", borderRadius: 10, padding: "4px 10px", color: "white", fontSize: 12, fontWeight: 700 }}>{idx + 1}/{WORDS.length}</div>
      </div>
      <div style={{ padding: "8px 16px 4px", flexShrink: 0 }}><PBar value={idx + 1} max={WORDS.length} color={T.teal} height={10} /></div>
      <TutorBubble mood={mood} message={tutorMsg} />

      <div style={{ flex: 1, overflowY: "auto", padding: "10px 16px 16px" }}>
        {/* Word card */}
        <div style={{
          background: `linear-gradient(135deg, ${T.teal}22, ${T.green}22)`,
          border: `3px solid ${T.teal}66`, borderRadius: 24, padding: "22px 20px", textAlign: "center",
          marginBottom: 12, animation: "bubblePop 0.35s cubic-bezier(.34,1.56,.64,1)",
          boxShadow: `0 8px 24px ${T.teal}30`,
        }}>
          <div style={{ fontSize: 72, marginBottom: 8 }}>{word.emoji}</div>
          <div style={{ fontSize: 56, color: T.tealD, fontFamily: "Georgia, serif", fontWeight: 900, direction: "rtl", marginBottom: 6 }}>{word.u}</div>
          <div style={{ fontSize: 15, fontWeight: 700, color: T.textMid }}>{word.r}</div>
          <div style={{ fontSize: 22, fontWeight: 900, color: T.text, marginTop: 4 }}>{word.eng}</div>
        </div>

        {/* Phoneme tiles */}
        <div style={{ background: "white", borderRadius: 18, padding: "14px 16px", marginBottom: 12, boxShadow: "0 2px 8px rgba(0,0,0,0.06)" }}>
          <div style={{ fontSize: 12, color: T.textMid, fontWeight: 700, marginBottom: 10 }}>حروف — Letters:</div>
          <div style={{ display: "flex", gap: 8, justifyContent: "center", flexWrap: "wrap" }}>
            {word.phonemes.map((ph, i) => {
              const status = getPhonemeStatus(ph);
              const color = !evalResult ? T.purple : status === "correct" ? T.greenD : status === "incorrect" ? T.red : T.teal;
              const bg    = !evalResult ? T.purple + "18" : status === "correct" ? T.green + "22" : status === "incorrect" ? T.red + "22" : T.teal + "22";
              return (
                <div key={i} style={{
                  width: 48, height: 48, borderRadius: 12,
                  background: bg, border: `3px solid ${color}66`,
                  display: "flex", alignItems: "center", justifyContent: "center",
                  fontSize: 22, fontFamily: "Georgia, serif", color: T.text,
                  fontWeight: 900, transition: "all 0.4s",
                  boxShadow: evalResult ? `0 4px 12px ${color}40` : "none",
                  position: "relative",
                }}>
                  {ph}
                  {evalResult && status === "correct" && <span style={{ position: "absolute", fontSize: 10, bottom: 2 }}>✓</span>}
                </div>
              );
            })}
          </div>
          {evalResult && (
            <div style={{ display: "flex", gap: 12, justifyContent: "center", marginTop: 10, flexWrap: "wrap" }}>
              {[{ color: T.greenD, bg: T.green + "22", label: "✓ Correct" }, { color: T.red, bg: T.red + "22", label: "✗ Needs work" }].map(({ color, bg, label }) => (
                <div key={label} style={{ display: "flex", alignItems: "center", gap: 4, fontSize: 11, color, fontWeight: 700 }}>
                  <div style={{ width: 12, height: 12, borderRadius: 3, background: bg, border: `2px solid ${color}` }} />
                  {label}
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Input area */}
        <div style={{ background: "white", borderRadius: 18, padding: "16px", boxShadow: "0 2px 8px rgba(0,0,0,0.06)", marginBottom: 12 }}>
          <div style={{ fontSize: 12, color: T.textMid, fontWeight: 700, marginBottom: 8 }}>
            🎤 Type how you pronounced it (romanized):
          </div>
          <div style={{ display: "flex", gap: 8 }}>
            <input
              value={userInput}
              onChange={handleInputChange}
              onFocus={() => setInputFocus(true)}
              onBlur={() => setInputFocus(false)}
              onKeyDown={e => e.key === "Enter" && handleEvaluate()}
              placeholder={`e.g. "${word.r}"`}
              style={{
                flex: 1, padding: "12px 14px", borderRadius: 12,
                border: `3px solid ${inputFocus ? T.teal : T.border}`,
                fontSize: 16, fontWeight: 700, outline: "none", color: T.text,
                background: "white", transition: "all 0.2s",
                boxShadow: inputFocus ? `0 0 0 4px ${T.teal}22` : "none",
              }}
            />
            {/* FIX: synchronous check — no spinner, instant result */}
            <Btn onClick={handleEvaluate} disabled={!userInput.trim()} color={T.teal} emoji="✅">
              Check
            </Btn>
          </div>
          <div style={{ fontSize: 11, color: T.textLight, marginTop: 6, fontStyle: "italic" }}>
            💡 Say the word aloud, then type it in Roman Urdu (e.g. "kitaab", "pani")
          </div>
        </div>

        {/* Evaluation result */}
        {evalResult && (
          <div style={{ background: "white", borderRadius: 18, padding: "16px", textAlign: "center", boxShadow: "0 2px 8px rgba(0,0,0,0.06)", animation: "bubblePop 0.3s ease", marginBottom: 12 }}>
            <div style={{ display: "flex", justifyContent: "center", marginBottom: 12 }}>
              <div style={{
                width: 90, height: 90, borderRadius: "50%",
                background: score > 75
                  ? `linear-gradient(135deg, ${T.green}, ${T.greenD})`
                  : score > 50
                  ? `linear-gradient(135deg, ${T.yellow}, ${T.yellowD})`
                  : `linear-gradient(135deg, ${T.red}, ${T.redL})`,
                display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center",
                boxShadow: `0 0 0 6px ${score > 75 ? T.green : score > 50 ? T.yellow : T.red}44`,
              }}>
                <div style={{ fontSize: 28, fontWeight: 900, color: "white", lineHeight: 1 }}>{score}%</div>
                <div style={{ fontSize: 11, color: "rgba(255,255,255,0.85)" }}>accuracy</div>
              </div>
            </div>

            <StarBadge count={score > 75 ? 3 : score > 50 ? 2 : 1} />

            {/* FIX: relabelled from "🤖 Ustaad AI says" to "Ustaad Munna says" */}
            <div style={{
              background: `linear-gradient(135deg, ${T.purple}10, ${T.teal}10)`,
              border: `2px solid ${T.purple}30`,
              borderRadius: 14, padding: "12px 14px", marginTop: 12, textAlign: "left",
            }}>
              <div style={{ fontSize: 12, color: T.purple, fontWeight: 800, marginBottom: 6 }}>🎓 Ustaad Munna says:</div>
              <div style={{ fontSize: 13, color: T.text, fontWeight: 600, lineHeight: 1.6 }}>
                {evalResult.feedback}
              </div>
            </div>

            <div style={{ marginTop: 10, display: "flex", flexDirection: "column", gap: 6, textAlign: "left" }}>
              {evalResult.correct_phonemes?.length > 0 && (
                <div style={{ background: T.green + "15", borderRadius: 10, padding: "8px 12px", fontSize: 12, color: T.greenD, fontWeight: 700 }}>
                  ✅ Correct: {evalResult.correct_phonemes.join("  ")}
                </div>
              )}
              {evalResult.incorrect_phonemes?.length > 0 && (
                <div style={{ background: T.red + "12", borderRadius: 10, padding: "8px 12px", fontSize: 12, color: T.red, fontWeight: 700 }}>
                  ❌ Incorrect: {evalResult.incorrect_phonemes.join("  ")}
                </div>
              )}
              {evalResult.missing_phonemes?.length > 0 && (
                <div style={{ background: T.orange + "12", borderRadius: 10, padding: "8px 12px", fontSize: 12, color: T.orange, fontWeight: 700 }}>
                  ⚠️ Missing: {evalResult.missing_phonemes.join("  ")}
                </div>
              )}
            </div>
          </div>
        )}
      </div>

      <div style={{ padding: "12px 16px 16px", display: "flex", gap: 10, flexShrink: 0 }}>
        <Btn onClick={() => { setEvalResult(null); setUserInput(""); }} color={T.teal} outline sm emoji="🔄">دوبارہ</Btn>
        <Btn onClick={handleNext} full color={T.teal} emoji="▶️">اگلا لفظ</Btn>
      </div>
    </div>
  );
}

// ─── JUMLAY ──────────────────────────────────────────────────────
// FIX: Removed Math.random() from score generation.
//      Replaced with a deterministic rule-based scorer that analyses
//      the typed sentence against the expected Urdu romanization.
function JumlayScreen({ onBack, onComplete }) {
  const [idx, setIdx]       = useState(0);
  const [wordIdx, setWordIdx] = useState(-1);
  const [phase, setPhase]   = useState("read");
  const [userInput, setUserInput] = useState("");  // FIX: typed input instead of fake speech
  const [inputFocus, setInputFocus] = useState(false);
  const [score, setScore]   = useState(null);
  const sent = SENTENCES[idx];

  const mood = phase === "read" ? "thinking" : score == null ? "neutral" : score > 70 ? "praise" : "sad";
  const tutorMsg = phase === "read"
    ? `Read the sentence! It means: "${sent.eng}" 📖`
    : score == null ? `Now type how you would say it! "${sent.u}" ✍️`
    : score > 70 ? "Brilliant! Perfect sentence! 🏆" : "Try again — go slowly! 🐢";

  useEffect(() => {
    if (phase !== "read") return;
    setWordIdx(-1);
    const timers = sent.words.map((_, i) => setTimeout(() => setWordIdx(i), (i + 1) * 700));
    return () => timers.forEach(clearTimeout);
  }, [idx, phase]);

  // FIX: deterministic sentence scoring
  // We compare the user's typed Roman version to a canonical Roman
  // representation built from the sentence's word list.
  const SENTENCE_ROMAN = [
    "mera naam raza hay",
    "mein school jata hoon",
    "yeh meri kitab hay",
    "aasmaan neela hay",
    "phool khubsoorat hain",
    "mein paani peeta hoon",
  ];

  const handleCheck = () => {
    if (!userInput.trim()) return;
    const result = evaluatePronunciationLocal(
      sent.u,
      SENTENCE_ROMAN[idx] || sent.u,
      sent.words,
      userInput.trim()
    );
    setScore(Math.round(result.accuracy));
  };

  const handleReset = () => {
    setPhase("read");
    setScore(null);
    setUserInput("");
  };

  const handleNext = () => {
    setIdx(i => (i + 1) % SENTENCES.length);
    setPhase("read");
    setScore(null);
    setUserInput("");
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", height: "100%", background: "linear-gradient(180deg,#fff4e6,#fff9f0)" }}>
      <div style={{ background: `linear-gradient(90deg, ${T.orange}, ${T.orangeL})`, padding: "12px 16px", display: "flex", alignItems: "center", gap: 12, flexShrink: 0 }}>
        <button onClick={onBack} style={{ background: "rgba(255,255,255,0.2)", border: "none", color: "white", fontSize: 18, cursor: "pointer", borderRadius: 10, width: 34, height: 34, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700 }}>←</button>
        <div style={{ fontWeight: 800, color: "white", fontSize: 15, flex: 1 }}>🗣️ جملے — Sentences</div>
        <div style={{ background: "rgba(255,255,255,0.2)", borderRadius: 10, padding: "4px 10px", color: "white", fontSize: 12, fontWeight: 700 }}>{idx + 1}/{SENTENCES.length}</div>
      </div>
      <div style={{ padding: "8px 16px 4px", flexShrink: 0 }}><PBar value={idx + 1} max={SENTENCES.length} color={T.orange} height={10} /></div>
      <TutorBubble mood={mood} message={tutorMsg} />
      <div style={{ flex: 1, overflowY: "auto", padding: "10px 16px 16px" }}>
        <div style={{ background: `linear-gradient(135deg, ${T.orange}18, ${T.yellow}18)`, border: `3px solid ${T.orange}55`, borderRadius: 24, padding: "22px 18px", marginBottom: 12, boxShadow: `0 8px 24px ${T.orange}25` }}>
          <div style={{ display: "flex", gap: 8, justifyContent: "flex-end", flexWrap: "wrap", direction: "rtl", marginBottom: 14 }}>
            {sent.words.map((w, i) => (
              <div key={i} style={{
                padding: "8px 14px", borderRadius: 12,
                background: i <= wordIdx ? T.orange + "25" : "rgba(0,0,0,0.04)",
                border: `2.5px solid ${i <= wordIdx ? T.orange : "rgba(0,0,0,0.08)"}`,
                color: i <= wordIdx ? T.orange : T.textLight,
                fontSize: 22, fontFamily: "Georgia, serif", fontWeight: 900,
                transition: "all 0.35s",
                transform: i === wordIdx ? "scale(1.1)" : "scale(1)",
                boxShadow: i === wordIdx ? `0 4px 12px ${T.orange}44` : "none",
              }}>{w}</div>
            ))}
          </div>
          <div style={{ borderTop: "2px dashed rgba(0,0,0,0.1)", paddingTop: 12, textAlign: "center", color: T.textMid, fontSize: 14, fontWeight: 600 }}>🇬🇧 {sent.eng}</div>
        </div>

        {phase === "read" && (
          <div style={{ textAlign: "center" }}>
            <Btn onClick={() => setPhase("speak")} color={T.orange} emoji="✍️">اب لکھیں! Type Now!</Btn>
          </div>
        )}

        {phase === "speak" && (
          <div style={{ background: "white", borderRadius: 18, padding: "16px", boxShadow: "0 2px 8px rgba(0,0,0,0.06)" }}>
            <div style={{ fontSize: 12, color: T.textMid, fontWeight: 700, marginBottom: 8 }}>
              ✍️ Type the sentence in Roman Urdu:
            </div>
            <div style={{ display: "flex", gap: 8, marginBottom: 10 }}>
              <input
                value={userInput}
                onChange={e => { setUserInput(e.target.value); setScore(null); }}
                onFocus={() => setInputFocus(true)}
                onBlur={() => setInputFocus(false)}
                onKeyDown={e => e.key === "Enter" && handleCheck()}
                placeholder={SENTENCE_ROMAN[idx] || "type the sentence..."}
                style={{
                  flex: 1, padding: "12px 14px", borderRadius: 12,
                  border: `3px solid ${inputFocus ? T.orange : T.border}`,
                  fontSize: 15, fontWeight: 700, outline: "none", color: T.text,
                  background: "white", transition: "all 0.2s",
                  boxShadow: inputFocus ? `0 0 0 4px ${T.orange}22` : "none",
                }}
              />
              <Btn onClick={handleCheck} disabled={!userInput.trim()} color={T.orange} emoji="✅">Check</Btn>
            </div>
            {/* Waveform kept as decorative score visualiser */}
            <Waveform active={false} score={score} />
            {score != null && (
              <div style={{ marginTop: 14, textAlign: "center", animation: "bubblePop 0.3s ease" }}>
                <div style={{ fontSize: 46, fontWeight: 900, color: score > 70 ? T.greenD : score > 50 ? T.yellowD : T.red }}>{score}%</div>
                <StarBadge count={score > 70 ? 3 : score > 50 ? 2 : 1} />
              </div>
            )}
          </div>
        )}
      </div>
      <div style={{ padding: "12px 16px 16px", display: "flex", gap: 10, flexShrink: 0 }}>
        <Btn onClick={handleReset} color={T.orange} outline sm emoji="🔄">دوبارہ</Btn>
        <Btn onClick={handleNext} full color={T.orange} emoji="▶️">اگلا جملہ</Btn>
      </div>
    </div>
  );
}

// ─── QUIZ ────────────────────────────────────────────────────────
// FIX: buildQuestions() now uses seededShuffle (deterministic).
//      Quiz instance is stable per component mount (useState init).
function QuizScreen({ onBack, user, onComplete }) {
  const [difficulty, setDifficulty] = useState(null);
  const [phase, setPhase]           = useState("setup");
  // FIX: questions are built once and never rebuilt randomly
  const [questions]                 = useState(() => buildQuestions());
  const [qIdx, setQIdx]             = useState(0);
  const [selected, setSelected]     = useState(null);
  const [score, setScore]           = useState(0);
  const [done, setDone]             = useState(false);
  const [showRes, setShowRes]       = useState(false);
  const [showConfetti, setShowConfetti] = useState(false);

  const q = questions[qIdx];
  const mood = showRes ? (selected === q?.answer ? "praise" : "sad") : "thinking";
  const tutorMsg = phase === "setup"
    ? "Choose difficulty! مشکل کا درجہ منتخب کریں! 🎮"
    : done ? (score >= 7 ? `Amazing ${user.name}! You're a star! 🌟` : `Good try ${user.name}! Practice more! 💪`)
    : showRes ? (selected === q.answer ? "Correct! شاباش! ✅" : "Wrong! غلط! ❌ Try next!")
    : `Question ${qIdx + 1}: ${q.q}`;

  const handleSelect = opt => {
    if (selected) return;
    setSelected(opt); setShowRes(true);
    if (opt === q.answer) {
      setScore(s => s + 1);
      setShowConfetti(true);
      setTimeout(() => setShowConfetti(false), 1500);
    }
    setTimeout(() => {
      if (qIdx < questions.length - 1) { setQIdx(i => i + 1); setSelected(null); setShowRes(false); }
      else setDone(true);
    }, 1400);
  };

  const difficultyOpts = [
    { d: "easy",   labelU: "آسان",    labelE: "Easy",   sub: "Letters only",    color: T.green,  icon: "🌱" },
    { d: "medium", labelU: "درمیانہ", labelE: "Medium", sub: "Words & Letters", color: T.yellow, icon: "⭐" },
    { d: "hard",   labelU: "مشکل",    labelE: "Hard",   sub: "Everything!",     color: T.pink,   icon: "🔥" },
  ];

  if (phase === "setup") return (
    <div style={{ display: "flex", flexDirection: "column", height: "100%", background: "linear-gradient(180deg,#fff0f6,#fff9f0)" }}>
      <div style={{ background: `linear-gradient(90deg,${T.pink},${T.pinkL})`, padding: "12px 16px", display: "flex", alignItems: "center", gap: 12, flexShrink: 0 }}>
        <button onClick={onBack} style={{ background: "rgba(255,255,255,0.2)", border: "none", color: "white", fontSize: 18, cursor: "pointer", borderRadius: 10, width: 34, height: 34, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700 }}>←</button>
        <div style={{ fontWeight: 800, color: "white", fontSize: 15, flex: 1 }}>🧩 کوئز — Quiz</div>
      </div>
      <TutorBubble mood="excited" message={tutorMsg} />
      <div style={{ flex: 1, padding: "14px 16px", display: "flex", flexDirection: "column", gap: 12 }}>
        <div style={{ fontWeight: 800, fontSize: 16, color: T.text, textAlign: "center" }}>Choose Difficulty! 🎯</div>
        {difficultyOpts.map(item => (
          <div key={item.d} onClick={() => setDifficulty(item.d)} style={{
            background: difficulty === item.d ? item.color + "22" : "white",
            border: `3px solid ${difficulty === item.d ? item.color : T.border}`,
            borderRadius: 20, padding: "16px 18px", cursor: "pointer", transition: "all 0.2s",
            display: "flex", alignItems: "center", gap: 14,
            transform: difficulty === item.d ? "scale(1.02)" : "scale(1)",
            boxShadow: difficulty === item.d ? `0 6px 20px ${item.color}44` : "0 2px 8px rgba(0,0,0,0.06)",
          }}>
            <span style={{ fontSize: 36 }}>{item.icon}</span>
            <div>
              <div style={{ fontWeight: 900, fontSize: 18, color: T.text, direction: "rtl" }}>{item.labelU} — {item.labelE}</div>
              <div style={{ color: T.textMid, fontSize: 13, fontWeight: 600 }}>{item.sub}</div>
            </div>
            {difficulty === item.d && <div style={{ marginLeft: "auto", fontSize: 22 }}>✅</div>}
          </div>
        ))}
      </div>
      <div style={{ padding: "12px 16px 24px" }}>
        <Btn full color={T.pink} disabled={!difficulty} onClick={() => setPhase("quiz")} emoji="🚀">شروع کریں! Start Quiz!</Btn>
      </div>
    </div>
  );

  if (done) {
    const pct = Math.round((score / questions.length) * 100);
    return (
      <div style={{ display: "flex", flexDirection: "column", height: "100%", background: "linear-gradient(180deg,#fff0f6,#fff9f0)", position: "relative", overflow: "hidden" }}>
        <Confetti active={pct >= 70} />
        <TutorBubble mood={pct >= 70 ? "praise" : "sad"} message={tutorMsg} />
        <div style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: 24, gap: 16, textAlign: "center" }}>
          <div style={{ fontSize: 72 }}>{pct >= 80 ? "🏆" : pct >= 60 ? "🎯" : "📚"}</div>
          <div style={{ fontWeight: 900, fontSize: 24, color: T.text, direction: "rtl" }}>کوئز مکمل!</div>
          <div style={{ fontWeight: 700, fontSize: 16, color: T.textMid }}>Quiz Complete!</div>
          <div style={{ width: 140, height: 140, borderRadius: "50%", background: pct >= 70 ? `linear-gradient(135deg,${T.green},${T.greenD})` : `linear-gradient(135deg,${T.red},${T.redL})`, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", boxShadow: pct >= 70 ? `0 0 0 8px ${T.green}44` : `0 0 0 8px ${T.red}44` }}>
            <div style={{ fontSize: 36, fontWeight: 900, color: "white" }}>{pct}%</div>
            <div style={{ fontSize: 14, color: "rgba(255,255,255,0.85)" }}>{score}/{questions.length}</div>
          </div>
          <StarBadge count={pct >= 80 ? 3 : pct >= 60 ? 2 : 1} />
          <div style={{ display: "flex", gap: 12, marginTop: 8 }}>
            <Btn onClick={() => { setQIdx(0); setScore(0); setDone(false); setSelected(null); setShowRes(false); setPhase("setup"); }} color={T.pink} emoji="🔄">دوبارہ</Btn>
            <Btn onClick={() => onComplete("quiz", pct, pct >= 80 ? 3 : pct >= 60 ? 2 : 1)} color={T.purple} emoji="🏠">گھر</Btn>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div style={{ display: "flex", flexDirection: "column", height: "100%", background: "linear-gradient(180deg,#fff0f6,#fff9f0)", position: "relative" }}>
      <Confetti active={showConfetti} />
      <div style={{ background: `linear-gradient(90deg,${T.pink},${T.pinkL})`, padding: "12px 16px", display: "flex", alignItems: "center", gap: 10, flexShrink: 0 }}>
        <button onClick={onBack} style={{ background: "rgba(255,255,255,0.2)", border: "none", color: "white", fontSize: 18, cursor: "pointer", borderRadius: 10, width: 34, height: 34, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700 }}>←</button>
        <div style={{ flex: 1 }}><PBar value={qIdx + 1} max={questions.length} color="rgba(255,255,255,0.6)" height={8} /></div>
        <div style={{ background: "rgba(255,255,255,0.2)", borderRadius: 10, padding: "4px 10px", color: "white", fontSize: 12, fontWeight: 700 }}>{qIdx + 1}/{questions.length} ⭐ {score}</div>
      </div>
      <TutorBubble mood={mood} message={tutorMsg} />
      <div style={{ flex: 1, overflowY: "auto", padding: "10px 16px 16px" }}>
        <div style={{ background: `linear-gradient(135deg,${T.pink}18,${T.purpleL}18)`, border: `3px solid ${T.pink}44`, borderRadius: 24, padding: "24px 18px", textAlign: "center", marginBottom: 14, animation: "bubblePop 0.3s ease", boxShadow: `0 8px 24px ${T.pink}25` }}>
          <div style={{ fontSize: 72, fontFamily: "Georgia, serif", color: T.purple, fontWeight: 900, marginBottom: 8 }}>{q.urdu}</div>
          <div style={{ color: T.textMid, fontSize: 14, fontWeight: 600 }}>{q.q}</div>
        </div>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
          {q.options.map((opt, i) => {
            const isCorrect = opt === q.answer, isSel = opt === selected;
            let bg = "white", border = T.border, color = T.text, shadow = "0 2px 8px rgba(0,0,0,0.06)";
            if (showRes) {
              if (isCorrect) { bg = T.green + "22"; border = T.greenD; color = T.greenD; shadow = `0 4px 16px ${T.green}44`; }
              else if (isSel) { bg = T.red + "22"; border = T.red; color = T.red; shadow = `0 4px 16px ${T.red}44`; }
            }
            return (
              <div key={i} onClick={() => handleSelect(opt)} style={{
                background: bg, border: `3px solid ${border}`, borderRadius: 18,
                padding: "16px 10px", textAlign: "center", cursor: "pointer",
                color, fontWeight: 800, fontSize: 15, transition: "all 0.2s",
                boxShadow: shadow, transform: isSel ? "scale(1.04)" : "scale(1)",
              }}>
                {opt}{showRes && isCorrect && " ✅"}{showRes && isSel && !isCorrect && " ❌"}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}

