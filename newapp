// Line 388 (approx) - UPDATE the map inside toPhonemes
function toPhonemes(word) {
  const map = [
    ["kh", "خ"], ["gh", "غ"], ["sh", "ش"], ["ch", "چ"],
    ["ph", "ف"], ["th", "ت"], ["dh", "د"], ["rh", "ڑ"] // Added rh for words like 'garh'
  ];

  let result = [];
  let i = 0;
  while (i < word.length) {
    let matched = false;
    for (let [key, val] of map) {
      if (word.slice(i, i + key.length) === key) {
        result.push(val);
        i += key.length;
        matched = true;
        break;
      }
    }
    if (!matched) {
      // If it's a standalone 'h' at the end or middle, give it a placeholder 
      // so it doesn't break the consonant mismatch penalty
      result.push(word[i]);
      i++;
    }
  }
  return result;
}
//Phenome scoring
function phonemeScore(user, expected) {
  let correct = [];
  let incorrect = [];
  let missing = [];

  let score = 0;

  const len = Math.max(user.length, expected.length);

  for (let i = 0; i < len; i++) {
    const u = user[i];
    const e = expected[i];

    if (!u && e) {
      missing.push(e);
      score -= 1;
    } 
    else if (u && !e) {
      score -= 0.5;
    }
    else if (u === e) {
      correct.push(e);
      score += 2;
    } 
    else {
      incorrect.push(e);

      // 🔥 consonant mismatch penalty
     // Inside phonemeScore function:
if (isConsonant(u) && isConsonant(e)) {
  score -= 1.0; // Reduced from 2.0 to 1.0 for leniency
} else {
  score -= 0.3; // Reduced from 0.5 to 0.3
}
    }
  }

  return { score, correct, incorrect, missing };
}
