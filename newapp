        <div style={{
          background: appPhase === "main" && screen !== "home" ? "transparent" : "rgba(255,255,255,0.6)",
          padding: "10px 22px 6px", display: "flex", justifyContent: "space-between", alignItems: "center", flexShrink: 0,
          backdropFilter: "blur(8px)",
        }}>
          <div style={{ color: T.textMid, fontSize: 11, fontWeight: 700 }}>
            {new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}
          </div>
          <div style={{ display: "flex", gap: 5, alignItems: "center" }}>
            <span style={{ fontSize: 11 }}>📶</span>
            <div style={{ width: 20, height: 10, border: `2px solid ${T.textMid}`, borderRadius: 3, padding: 1 }}>
              <div style={{ width: "80%", height: "100%", background: T.green, borderRadius: 1 }} />
            </div>
          </div>
        </div>
        {badge && <BadgePopup badge={badge} onClose={() => setBadge(null)} />}
        {appPhase === "splash" && <SplashScreen onDone={() => setAppPhase("setup")} />}
        {appPhase === "setup" && <SetupScreen onDone={(name, gender) => { setUser({ name, gender }); setAppPhase("main"); }} />}
        {appPhase === "main" && (
          <div style={{ flex: 1, overflow: "hidden", display: "flex", flexDirection: "column" }}>
            <div style={{ flex: 1, overflow: "hidden" }}>
              {screen === "home"   && <HomeScreen user={user} onNav={setScreen} completedMap={completedMap} stars={stars} />}
              {screen === "haroof" && <HaroofScreen onBack={() => setScreen("home")} onComplete={handleComplete} />}
              {screen === "lafz"   && <LafzScreen onBack={() => setScreen("home")} onComplete={handleComplete} />}
              {screen === "jumlay" && <JumlayScreen onBack={() => setScreen("home")} onComplete={handleComplete} />}
              {screen === "quiz"   && <QuizScreen onBack={() => setScreen("home")} user={user} onComplete={handleComplete} />}
            </div>
            <BottomNav screen={screen} onNav={setScreen} />
          </div>
        )}
      </div>
    </>
  );
}
