//Score and accuracy mapping
function mapScoreToAccuracy(score) {
  if (score >= 8) return 95;
  if (score >= 5) return 85;
  if (score >= 2) return 70;
  if (score >= 0) return 55;
  return 35;
}
//Feedback
function generateFeedback(acc, word) {
  if (acc >= 90) return `Excellent! "${word}" 🎉`;
  if (acc >= 75) return `Good job! Try refining it 💪`;
  if (acc >= 55) return `You're close! Practice slowly 🐢`;
  return `Try again: "${word}" 📖`;
}
//base result helper
function baseResult(acc, phonemes, msg) {
  return {
    accuracy: acc,
    correct_phonemes: [],
    incorrect_phonemes: phonemes,
    missing_phonemes: phonemes,
    feedback: msg,
  };
}

